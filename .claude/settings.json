{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pio run:*)",
      "Bash(pio device monitor:*)",
      "Bash(pio test:*)",
      "Bash(pio lib:*)",
      "Bash(pio pkg:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(shasum:*)",
      "Bash(date:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(printenv:*)",
      "Bash(pwd:*)",
      "Bash(whoami:*)",
      "Bash(uname:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git stash list:*)",
      "Bash(git remote -v:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(npm run:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",

      "Bash(bash -n:*)",
      "Bash(.ccanvil/scripts/docs-check.sh:*)",
      "Bash(.ccanvil/scripts/security-audit.sh:*)",
      "Bash(.ccanvil/scripts/permissions-audit.sh:*)",
      "Bash(.ccanvil/scripts/context-budget.sh:*)",
      "Bash(.ccanvil/scripts/manifest-check.sh:*)",
      "Bash(./.ccanvil/scripts/ccanvil-sync.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf .)*",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(kill -9:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-on-write.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-on-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/branch-name-lint.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/commit-msg-lint.sh"
          }
        ]
      }
    ]
  }
}
